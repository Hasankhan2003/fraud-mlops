groups:
- name: fraud_detection_alerts
  rules:
  # Trigger when Recall drops (Cost-sensitive priority)
  - alert: FraudRecallDrop
    expr: model_fraud_recall < 0.85
    for: 5m
    labels:
      severity: critical
      action: trigger_retraining
    annotations:
      summary: "Model Recall Drop Detected"
      description: "Fraud recall has dropped below 85%. False negatives are increasing. Triggering CI/CD."

  # Trigger when Data Drift exceeds threshold
  - alert: HighDataDrift
    expr: feature_drift_score > 0.20
    for: 10m
    labels:
      severity: warning
      action: trigger_retraining
    annotations:
      summary: "Data Drift Exceeded"
      description: "Data drift score is {{ $value }}. Distribution of transactions shifted."

  # Trigger on System Latency Spikes
  - alert: HighApiLatency
    expr: http_request_duration_seconds > 2.0
    for: 2m
    labels:
      severity: critical
    annotations:
      summary: "API Latency Spike"
      description: "Inference API is taking longer than 2 seconds to respond."
